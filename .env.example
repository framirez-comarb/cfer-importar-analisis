# Copiar a .env y completar los valores.
# .env esta en .gitignore — nunca commitearlo.

# Property ID de la propiedad GA4 de CFER web (sifereweb.comarb.gob.ar)
GA4_PROPERTY_ID=373855714

# Path absoluto al JSON de service account de GA4.
# El mismo SA que usan los repos ps-flujo-comarb y ps-verificacion-comarb.
# Service account: ga4-reader@comarb-analytics.iam.gserviceaccount.com
GA4_SA_PATH=C:\Users\FARP\Documents\Proyects\Fede4\comarb-analytics-580ca8f5412c.json

# Rango del analisis.
# - FECHA_DESDE: requerido (la consigna pide al menos junio 2025)
# - FECHA_HASTA: opcional. Si esta vacio, usa "today" (hoy).
FECHA_DESDE=2025-06-01
FECHA_HASTA=
